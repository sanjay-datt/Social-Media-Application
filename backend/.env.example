# Port the Express server listens on
PORT=5000

# MongoDB connection string.
# Option A — Local MongoDB (must be installed and running on your machine):
MONGO_URI=mongodb://localhost:27017/socialmedia
# Option B — MongoDB Atlas (free cloud database, no local install needed).
# Replace <username>, <password>, and <cluster> with your own Atlas values:
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/socialmedia?retryWrites=true&w=majority

# Secret key used to sign and verify JWT tokens.
# Generate one by running this command in your terminal:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Then paste the output here. Keep this value private and never commit it.
JWT_SECRET=your_jwt_secret_here
